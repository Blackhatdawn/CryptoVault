{
  "expo": {
    "name": "CryptoVault",
    "slug": "cryptovault-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "cryptovault",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08091A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cryptovault.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "We use Face ID to secure your wallet and enable quick login",
        "NSCameraUsageDescription": "We need camera access to scan QR codes for crypto addresses"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#08091A"
      },
      "package": "com.cryptovault.mobile",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/images/logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow CryptoVault to use Face ID for secure login"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CryptoVault to scan QR codes for crypto addresses"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7b9c8f5e-4a2d-11ed-8f29-0242ac120002"
      }
    }
  }
}
